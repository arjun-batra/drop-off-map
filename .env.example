# Local development environment variables for DropSpot.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Never commit real secret values. See docs/design.md section 7 and
# docs/runbook.md section 4 for the authoritative schema.

# --- Provider ---
MAP_ROUTING_PROVIDER=google_maps_platform
MAP_API_KEY=replace-with-a-real-google-maps-platform-key

# --- Service area (NFR-006, FR-004) ---
GEOGRAPHIC_CENTER={"lat":43.6532,"lng":-79.3832,"label":"Toronto, ON"}
GEOGRAPHIC_RADIUS_KM=200

# --- Results shaping ---
MAX_CANDIDATES_RETURNED=3

# --- Access control (FR-016, FR-017) ---
# free_tier = fully open. paid_tier = entire app requires PAID_TIER_ACCESS_PASSWORD.
APP_MODE=free_tier
# Required only when APP_MODE=paid_tier; config loader fails fast otherwise.
PAID_TIER_ACCESS_PASSWORD=
# REV-002 (INC-8): how long a session cookie stays valid after a correct
# password check, in seconds. The cookie's own Max-Age matches this value,
# and the server independently re-checks the embedded signed expiry on every
# request (src/auth/session.ts) -- it does not rely on the browser alone to
# drop an expired cookie. 3600 = 1 hour.
SESSION_LIFETIME_SECONDS=3600

# --- Latency (NFR-004) ---
RESPONSE_TIME_TARGET_SECONDS=5
REQUEST_TIMEOUT_MS=4000

# --- Transit ---
# "all" or a comma-separated list, e.g. bus,subway,tram
TRANSIT_MODES_INCLUDED=all

# --- Geocode autocomplete cost controls (design.md section 7.1, REV-006/REV-007) ---
MIN_GEOCODE_QUERY_LENGTH=3
GEOCODE_DEBOUNCE_MS=300

# --- Candidate generation / evaluation tuning (section 4, design.md) ---
CANDIDATE_SPACING_METERS=1000
MAX_RAW_CANDIDATES_SAMPLED=20
MAX_TRANSIT_EVALUATIONS_PER_REQUEST=8
DISTANCE_MATRIX_BATCH_SIZE=25
PROVIDER_CONCURRENCY_LIMIT=10

# --- Map view (INC-10, FR-022, design.md section 7.2, ux-spec.md section 6.7) ---
# Renders the Results-screen map via Google's Maps JavaScript API (Dynamic
# Maps), replacing INC-9's Leaflet + MAP_TILE_URL_TEMPLATE/MAP_TILE_ATTRIBUTION
# implementation (both retired by this increment).
#
# OPTIONAL -- unlike most keys in this file, leave this blank and the
# Results-screen map panel is simply omitted; the rest of the app is
# unaffected (ux-spec.md section 6.7's "fail silently, omit the panel").
#
# IMPORTANT: this must be a DISTINCT key from MAP_API_KEY above, not the same
# value (DEC-7, requirements.md section 5; design.md section 7.2). This key
# is loaded via a client-side <script> tag and is therefore necessarily
# visible in the browser (view-source/dev tools) -- that is expected for
# this specific Google product, but it means it needs a DIFFERENT Google
# Cloud Console restriction than MAP_API_KEY:
#   - Application restriction: HTTP referrers (websites) -- limit to this
#     app's actual production/preview domain(s).
#   - API restriction: Maps JavaScript API only.
# MAP_API_KEY above must remain a server-side-only credential (no HTTP
# referrer restriction makes sense for it, since it's never called from a
# browser) -- reusing one key for both would force picking one restriction
# type for both purposes, weakening whichever one loses, and would mean a
# leaked browser key could call this app's own billed Directions/Distance
# Matrix/Geocoding APIs directly, bypassing every cost control this app has
# (radius gating, APP_MODE, candidate-count limits, etc.).
GOOGLE_MAPS_JS_API_KEY=
