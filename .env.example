# Local development environment variables for DropSpot.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Never commit real secret values. See docs/design.md section 7 and
# docs/runbook.md section 4 for the authoritative schema.

# --- Provider ---
MAP_ROUTING_PROVIDER=google_maps_platform
MAP_API_KEY=replace-with-a-real-google-maps-platform-key

# --- Service area (NFR-006, FR-004) ---
GEOGRAPHIC_CENTER={"lat":43.6532,"lng":-79.3832,"label":"Toronto, ON"}
GEOGRAPHIC_RADIUS_KM=200

# --- Results shaping ---
MAX_CANDIDATES_RETURNED=3

# --- Access control (FR-016, FR-017) ---
# free_tier = fully open. paid_tier = entire app requires PAID_TIER_ACCESS_PASSWORD.
APP_MODE=free_tier
# Required only when APP_MODE=paid_tier; config loader fails fast otherwise.
PAID_TIER_ACCESS_PASSWORD=

# --- Latency (NFR-004) ---
RESPONSE_TIME_TARGET_SECONDS=5
REQUEST_TIMEOUT_MS=4000

# --- Transit ---
# "all" or a comma-separated list, e.g. bus,subway,tram
TRANSIT_MODES_INCLUDED=all

# --- Geocode autocomplete cost controls (design.md section 7.1, REV-006/REV-007) ---
MIN_GEOCODE_QUERY_LENGTH=3
GEOCODE_DEBOUNCE_MS=300

# --- Candidate generation / evaluation tuning (section 4, design.md) ---
CANDIDATE_SPACING_METERS=1000
MAX_RAW_CANDIDATES_SAMPLED=20
MAX_TRANSIT_EVALUATIONS_PER_REQUEST=8
DISTANCE_MATRIX_BATCH_SIZE=25
PROVIDER_CONCURRENCY_LIMIT=10
