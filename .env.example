# Local development environment variables for DropSpot.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Never commit real secret values. See docs/design.md section 7 and
# docs/runbook.md section 4 for the authoritative schema.

# --- Provider ---
MAP_ROUTING_PROVIDER=google_maps_platform
MAP_API_KEY=replace-with-a-real-google-maps-platform-key

# --- Service area (NFR-006, FR-004) ---
GEOGRAPHIC_CENTER={"lat":43.6532,"lng":-79.3832,"label":"Toronto, ON"}
GEOGRAPHIC_RADIUS_KM=200

# --- Results shaping ---
MAX_CANDIDATES_RETURNED=3

# --- Access control (FR-016, FR-017) ---
# free_tier = fully open. paid_tier = entire app requires PAID_TIER_ACCESS_PASSWORD.
APP_MODE=free_tier
# Required only when APP_MODE=paid_tier; config loader fails fast otherwise.
PAID_TIER_ACCESS_PASSWORD=
# REV-002 (INC-8): how long a session cookie stays valid after a correct
# password check, in seconds. The cookie's own Max-Age matches this value,
# and the server independently re-checks the embedded signed expiry on every
# request (src/auth/session.ts) -- it does not rely on the browser alone to
# drop an expired cookie. 3600 = 1 hour.
SESSION_LIFETIME_SECONDS=3600

# --- Latency (NFR-004) ---
RESPONSE_TIME_TARGET_SECONDS=5
REQUEST_TIMEOUT_MS=4000

# --- Transit ---
# "all" or a comma-separated list, e.g. bus,subway,tram
TRANSIT_MODES_INCLUDED=all

# --- Geocode autocomplete cost controls (design.md section 7.1, REV-006/REV-007) ---
MIN_GEOCODE_QUERY_LENGTH=3
GEOCODE_DEBOUNCE_MS=300

# --- Candidate generation / evaluation tuning (section 4, design.md) ---
CANDIDATE_SPACING_METERS=1000
MAX_RAW_CANDIDATES_SAMPLED=20
MAX_TRANSIT_EVALUATIONS_PER_REQUEST=8
DISTANCE_MATRIX_BATCH_SIZE=25
PROVIDER_CONCURRENCY_LIMIT=10

# --- Map view (INC-9, design.md section 3.1a/10, ux-spec.md section 6.7) ---
# Both keys below are OPTIONAL -- unlike every other key in this file, leave
# either one unset/blank and the Results-screen map panel is simply omitted
# (the app runs fine without it; INC-9 is an explicitly optional/conditional
# enhancement per design.md section 10, not required by any FR/NFR).
#
# Non-Google tile provider for the optional Results-screen map (Leaflet).
# Deliberately NOT the Google Maps JavaScript API (that would draw down the
# same shared Google Maps Platform billing pool as the Directions/Distance
# Matrix/Geocoding calls above -- see design.md section 3.1a) and NOT the raw
# OpenStreetMap demo tile server (tile.openstreetmap.org has a
# production-usage policy against exactly this kind of traffic and can
# rate-limit/block the app).
#
# Default below points at CARTO's free "Positron" basemap
# (https://carto.com/basemaps), which is keyless/anonymous (no account or API
# key needed) -- chosen specifically so this app works out of the box in a
# fresh environment/sandbox with zero setup, while still being a real
# managed provider rather than the discouraged raw-OSM demo server. It is
# rate-limited for high-volume production traffic, same caveat design.md
# flags for any free tier.
#
# For a real production deployment at meaningful volume, get a free-tier
# account with MapTiler (https://www.maptiler.com/cloud/) or Stadia Maps
# (https://stadiamaps.com/) instead, and set MAP_TILE_URL_TEMPLATE to the
# URL template your account dashboard gives you (embed your API key directly
# in the string, e.g. `...png?key=YOUR_KEY`) -- no code change needed, this
# is purely a config swap. Update MAP_TILE_ATTRIBUTION to match whichever
# provider you choose (copy the exact attribution text/HTML their docs
# require).
MAP_TILE_URL_TEMPLATE=https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png
MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>
